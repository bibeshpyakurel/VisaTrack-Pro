{
  "name": "visatrack-pro-backend",
  "version": "1.0.0",
  "description": "VisaTrack Pro backend — H-1B employer intelligence API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "import": "node scripts/importCSV.js",
    "sync:uscis": "node scripts/syncUSCIS.js",
    "sync:lca": "node -e \"require('./services/lcaSync').runLcaSync({triggerSource:'cli'}).then(r=>console.log('Done:',r.run.records_imported,'records')).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "seed:demo": "node scripts/seedDemo.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "node-cron": "^4.0.5",
    "openai": "^4.52.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
