OPENAI_API_KEY=your_openai_api_key_here
PORT=3001
FRONTEND_URL=http://localhost:5173
DB_PATH=./h1b.db
USCIS_SYNC_ON_STARTUP=true
USCIS_SYNC_SCHEDULE_ENABLED=true
USCIS_SYNC_SCHEDULE=0 5 15 1 *
# Optional: comma-separated list such as 2021,2022,2023
USCIS_SYNC_YEARS=
# Optional: lock down POST /api/admin/refresh with this token
ADMIN_API_TOKEN=
